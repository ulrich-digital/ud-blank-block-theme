{
  "name": "ulrichdigital_block_theme",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "sass src/scss/style.scss:build/style.css src/scss/blocks.scss:build/blocks.css src/scss/editor.scss:build/editor.css --no-source-map",
    "watch:css": "sass --watch src/scss/style.scss:build/style.css src/scss/blocks.scss:build/blocks.css src/scss/editor.scss:build/editor.css --no-source-map",
    "build:js": "esbuild src/js/frontend.js src/js/editor.js src/js/development.js --bundle --outdir=build --format=iife",
    "watch:js": "esbuild src/js/frontend.js src/js/editor.js src/js/development.js --bundle --outdir=build --format=iife --watch",
    "build": "npm run build:css && npm run build:js",
    "watch": "concurrently \"npm run watch:css\" \"npm run watch:js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.12",
    "sass": "^1.92.1"
  }
}
